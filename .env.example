# ─────────────────────────────────────────────────────────────────
# JARVIS MK2 — Configurazione ambiente
# Copia questo file in `.env` e compila SOLO le chiavi che ti servono.
# Tutto è opzionale: JARVIS MK2 funziona local-first con Ollama.
# ─────────────────────────────────────────────────────────────────

# ── Persona ─────────────────────────────────────────────────────
JARVIS_PERSONA_LANG=it           # it | en
JARVIS_PERSONA_NAME=JARVIS
JARVIS_USER_NAME=Signore

# ── LLM locale (Ollama) ─────────────────────────────────────────
# Usa `ollama list` per vedere i modelli installati e adatta i valori.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_FAST=qwen3:8b       # modello veloce (es. qwen3:8b, qwen2.5:7b)
OLLAMA_MODEL_HEAVY=qwen3:14b     # modello pesante per swarm (es. qwen3:14b, qwen2.5:14b)
OLLAMA_KEEP_ALIVE_FAST=30m       # tieni in RAM (NO "-1" — causa 400!)
OLLAMA_KEEP_ALIVE_HEAVY=0s       # staffetta VRAM (Apple Silicon 16GB)

# ── Cloud fallback (opzionale) ──────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=                  # serve anche per embeddings memoria episodica

# ── Kimi Code CLI (locale) ─────────────────────────────────────
# Installato con: curl -fsSL https://kimi.ai/install | sh
# Login: kimi login — nessuna API key necessaria (OAuth)
# Verifica: kimi -p "test" --quiet

# ── Voce — STT (Groq Whisper, italiano) ─────────────────────────
GROQ_API_KEY=                    # vuoto = fallback Google STT locale
JARVIS_WAKE_WORDS=jarvis,ehi jarvis,hey jarvis

# ── Voce — TTS (ElevenLabs, fallback macOS say) ─────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB    # Adam, britannico
JARVIS_MACOS_VOICE_IT=Alice
JARVIS_MACOS_VOICE_EN=Daniel

# ── Connettori ──────────────────────────────────────────────────
OBSIDIAN_VAULT_PATH=             # es. /Users/tu/Documents/Vault
JARVIS_OBSIDIAN_SUBDIR=Jarvis    # sottocartella del vault per cervello/clienti/errori

# ── Canali ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=       # CSV, es. "12345,67890"

# ── Server ──────────────────────────────────────────────────────
JARVIS_HOST=127.0.0.1
JARVIS_PORT=8765
JARVIS_FRONTEND_ORIGIN=http://localhost:5173

# ── Storage ─────────────────────────────────────────────────────
# Priority: JARVIS_DATA_DIR > Obsidian vault > ~/.jarvismk2
# Se OBSIDIAN_VAULT_PATH è configurato, i dati vanno automaticamente in 
# <vault>/.jarvis/ (cervello, skills, memoria episodica, learning)
# Così tutto è sincronizzato su iCloud e visibile in Obsidian!
JARVIS_DATA_DIR=                 # esplicito: sovrascrive tutto (lascia vuoto per Obsidian)

# ── Connettori (Obsidian come cervello) ──────────────────────────
# Quando OBSIDIAN_VAULT_PATH è settato, JARVIS usa quel vault come "cervello esterno"
# I dati persistenti vanno in .jarvis/ (nascosta), le note sync in Jarvis/
OBSIDIAN_VAULT_PATH=/Users/giacomotronconi/Library/Mobile Documents/iCloud~md~obsidian/Documents/MK2/MK2
JARVIS_OBSIDIAN_SUBDIR=Jarvis    # sottocartella visibile per note sync

# ── Logging ─────────────────────────────────────────────────────
JARVIS_LOG_LEVEL=INFO
